# Copy this file to .env and fill in the values you need.
# You only need the lines for the features you actually use — leave the rest blank.

# --- Uploading scraped data to Supabase (only if you use `--upload`) ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Running the form-filling worker (`suu poll`) ---
# The address of the receipt-gatherer web app it should read jobs from.
APP_URL=
# A shared password the worker uses to prove it's allowed to read jobs.
WORKER_AUTH_TOKEN=

# --- Optional: where suu keeps your saved logins (defaults to ~/.suu) ---
# SUU_HOME=
